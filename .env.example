// Variables de entorno necesarias para el CRM Hub
// Copia este archivo como .env y llena los valores

# ---- NextAuth ----
AUTH_SECRET="coloca_un_secreto_largo_aqui_minimo_32_caracteres"

# ---- Firebase Admin SDK ----
# Ve a Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID="crm-3640a"
FIREBASE_CLIENT_EMAIL="coloca_el_client_email_del_service_account"
FIREBASE_PRIVATE_KEY="coloca_la_private_key_del_service_account_con_saltos_de_linea"
